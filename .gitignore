@"
# Virtual environment
venv/

# Dataset (too large for git) — root data/ only
/data/

# Trained model checkpoints
checkpoints/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# W&B logs
wandb/

# Package build artifacts
*.egg-info/
dist/
build/

# Environment secrets
.env
env.ps1

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Temp files
tmp/
temp/
"@ | Out-File -FilePath .gitignore -Encoding utf8